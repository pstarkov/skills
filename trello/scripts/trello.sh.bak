#!/usr/bin/env bash
# Trello REST API - Consolidated Bash Functions
# This script contains all 256 Trello API endpoint functions
# Source this file: source trello.sh
#
# Usage: trello_<verb>_<resource> base_url api_key token [params...]
#
# Examples:
#   trello_get_cards https://api.trello.com/1 $KEY $TOKEN
#   trello_post_cards https://api.trello.com/1 $KEY $TOKEN idList=abc123 name="My Card"

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

# Check that API credentials are provided
_trello_validate_auth() {
    if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
        echo "Error: API key and token required" >&2
        return 1
    fi
    return 0
}

# ============================================================================
# ENDPOINT FUNCTIONS (Autogenerated from 256 Trello endpoints)
# ============================================================================


# DELETE /actions/{id}
# Delete a specific action. Only comment actions can be deleted.
trello_delete_actions_id() {
    local base_url="${1}"
    local api_key="${2}"
    local token="${3}"
    shift 3
    
    _trello_validate_auth "$api_key" "$token" || return 1
    
    local endpoint="/actions/{id}"
    local method="DELETE"
    local url="${base_url}${endpoint}?key=${api_key}&token=${token}"
    
    # Pass through all remaining arguments as query/body parameters
    if [ $# -gt 0 ]; then
        url="${url}&$@"
    fi
    
    curl -s -X "$method" "$url"
}

