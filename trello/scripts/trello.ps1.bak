# Trello REST API - Consolidated PowerShell Functions
# This script contains all 256 Trello API endpoint functions
# Dot-source this file: . ./trello.ps1

$ErrorActionPreference = 'Stop'

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

function Test-TrelloAuth {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)]
        [string]$ApiKey,

        [Parameter(Mandatory=$true)]
        [string]$Token
    )

    if ([string]::IsNullOrEmpty($ApiKey) -or [string]::IsNullOrEmpty($Token)) {
        Write-Error "API key and token are required"
        return $false
    }
    return $true
}

# ============================================================================
# ENDPOINT FUNCTIONS (Autogenerated from 256 Trello endpoints)
# ============================================================================


function Remove-TrelloActions {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$false)]
        [string]$BaseUrl = 'https://api.trello.com/1',
        
        [Parameter(Mandatory=$true)]
        [string]$ApiKey,
        
        [Parameter(Mandatory=$true)]
        [string]$Token,
        
        [Parameter(Mandatory=$false)]
        [hashtable]$Params = @{}
    )
    
    if (-not (Test-TrelloAuth -ApiKey $ApiKey -Token $Token)) { return }
    
    $endpoint = "/actions/{id}"
    $url = "$BaseUrl$endpoint?key=$ApiKey&token=$Token"
    
    # Add additional parameters to URL
    foreach ($key in $Params.Keys) {
        $url += "&$key=$($Params[$key])"
    }
    
    Invoke-WebRequest -Uri $url -Method DELETE
}

